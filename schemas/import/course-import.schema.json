{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kursnavi.local/schemas/import/course-import.schema.json",
  "title": "KursNavi Course Import Drafts",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "courses"],
  "$defs": {
    "evidenceString": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "source_url", "evidence_text"],
      "properties": {
        "value": { "type": "string", "minLength": 1 },
        "source_url": { "type": "string", "format": "uri" },
        "evidence_text": { "type": "string", "minLength": 1 },
        "needs_review": { "type": "boolean" }
      }
    },
    "optionalEvidenceString": { "anyOf": [{ "$ref": "#/$defs/evidenceString" }, { "type": "null" }] },
    "evidenceNumber": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "source_url", "evidence_text", "needs_review"],
      "properties": {
        "value": { "type": "number", "minimum": 0 },
        "currency": { "const": "CHF" },
        "source_url": { "type": "string", "format": "uri" },
        "evidence_text": { "type": "string", "minLength": 1 },
        "needs_review": { "const": true }
      }
    },
    "evidenceDateTime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "source_url", "evidence_text", "needs_review"],
      "properties": {
        "value": { "type": "string", "format": "date-time" },
        "source_url": { "type": "string", "format": "uri" },
        "evidence_text": { "type": "string", "minLength": 1 },
        "needs_review": { "const": true }
      }
    },
    "imageCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "source_url", "rights_status", "needs_review"],
      "properties": {
        "url": { "type": "string", "format": "uri" },
        "source_url": { "type": "string", "format": "uri" },
        "evidence_text": { "type": "string" },
        "rights_status": { "const": "unknown" },
        "needs_review": { "const": true }
      }
    }
  },
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "courses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["external_id", "title", "status", "booking_type", "country", "location", "price", "dates"],
        "properties": {
          "external_id": { "type": "string", "minLength": 1 },
          "title": { "$ref": "#/$defs/evidenceString" },
          "description": { "$ref": "#/$defs/optionalEvidenceString" },
          "category_hint": { "$ref": "#/$defs/optionalEvidenceString" },
          "status": { "const": "draft" },
          "booking_type": { "const": "lead" },
          "country": { "const": "CH" },
          "location": { "$ref": "#/$defs/evidenceString" },
          "price": { "anyOf": [{ "$ref": "#/$defs/evidenceNumber" }, { "type": "null" }] },
          "dates": { "type": "array", "items": { "$ref": "#/$defs/evidenceDateTime" }, "default": [] },
          "image_candidates": { "type": "array", "items": { "$ref": "#/$defs/imageCandidate" }, "default": [] }
        }
      }
    }
  }
}
