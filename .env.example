# ===========================================
# KursNavi Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control!

# ===========================================
# Supabase Configuration
# ===========================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_KEY=your-anon-key-here

# Server-side only (for API routes)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ===========================================
# Stripe Configuration
# ===========================================
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ===========================================
# Email Service (Resend)
# ===========================================
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM="KursNavi <info@kursnavi.ch>"
SUPPORT_EMAIL=info@kursnavi.ch
ADMIN_EMAIL=info@kursnavi.ch

# ===========================================
# Admin Console
# ===========================================
ADMIN_CONSOLE_SECRET=your-secure-admin-secret

# ===========================================
# Newsletter (Brevo)
# ===========================================
BREVO_API_KEY=xkeysib-your-brevo-api-key

# ===========================================
# Security / Hashing
# ===========================================
LEAD_HASH_SALT=your-random-salt-here

# ===========================================
# Google Analytics 4
# ===========================================
# Measurement ID is set directly in index.html (public, no secret)
# GA4 Property: https://analytics.google.com
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ===========================================
# Site Configuration
# ===========================================
VITE_SITE_URL=https://kursnavi.ch

# ===========================================
# E2E Test Configuration (optional)
# ===========================================
# Only needed for hybrid app-e2e tests (npm run test:e2e:app)
# See TESTING.md for setup instructions
# SUPABASE_URL_TEST=https://your-test-project.supabase.co
# SUPABASE_PUBLISHABLE_KEY_TEST=your-test-anon-key
# SUPABASE_SECRET_KEY_TEST=your-test-service-role-key
# E2E_PROVIDER_EMAIL=provider@test.com
# E2E_PROVIDER_PASSWORD=test-password
# E2E_PROVIDER_ID=uuid-of-teacher-auth-user
# E2E_LEARNER_EMAIL=learner@test.com
# E2E_LEARNER_PASSWORD=test-password
# E2E_LEARNER_ID=uuid-of-learner-auth-user
