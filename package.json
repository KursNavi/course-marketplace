{
  "name": "course-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:playwright": "node scripts/start-playwright-dev.mjs",
    "build": "vite build && node scripts/prerender-static.mjs",
    "lint": "eslint .",
    "check:mojibake": "node scripts/check-mojibake.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test --config=playwright.config.mjs",
    "test:e2e:harness": "playwright test --config=playwright.config.mjs --project=harness",
    "test:e2e:app": "playwright test --config=playwright.config.mjs --project=app-e2e",
    "seed:e2e": "node scripts/seed-e2e.mjs",
    "verify:e2e-schema": "node scripts/verify-e2e-schema.mjs",
    "test:watch": "vitest",
    "retest:security": "node scripts/security-retest.mjs",
    "dev:finalize-yoga": "node scripts/finalize-yoga-cleanup-dev.mjs",
    "cleanup:check": "node scripts/cleanup-images.js --dry-run",
    "cleanup:execute": "node scripts/cleanup-images.js --execute"
  },
  "dependencies": {
    "@sentry/react": "^10.43.0",
    "@supabase/supabase-js": "^2.86.0",
    "@vercel/analytics": "^2.0.1",
    "browser-image-compression": "^2.0.2",
    "lucide-react": "^0.555.0",
    "pdfkit": "^0.17.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-helmet-async": "^2.0.5",
    "resend": "^6.5.2",
    "stripe": "^20.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.22",
    "dotenv": "^16.4.5",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.6",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^3.4.16",
    "vite": "^7.2.4",
    "vitest": "^4.0.18"
  }
}
